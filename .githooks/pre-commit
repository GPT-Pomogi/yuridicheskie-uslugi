#!/bin/sh

set -eu

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM)"

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

for file in $STAGED_FILES; do
  case "$file" in
    .env.example)
      continue
      ;;
    .env|*.env|*.env.*|*.pem|*.key|*.p12|*.pfx|*.crt|*.cer|id_rsa|id_rsa.pub|*secrets*|*credentials*)
      echo "Commit blocked: staged files look like secrets or private keys."
      echo "Remove them from git before committing."
      exit 1
      ;;
  esac
done

git diff --cached -- . ':(exclude).env.example' | grep -E 'BEGIN (RSA|EC|OPENSSH|DSA|PGP) PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9]{20,}|OPENAI_API_KEY=|DATABASE_URL=.*@|AWS_SECRET_ACCESS_KEY=|-----BEGIN CERTIFICATE-----' >/dev/null 2>&1 && {
  echo "Commit blocked: potential secret detected in staged content."
  echo "Review the staged diff and move secrets to local environment variables."
  exit 1
}

exit 0
